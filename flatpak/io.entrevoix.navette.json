{
  "id": "io.entrevoix.navette",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "navetted",
  "finish-args": [
    "--share=network",
    "--filesystem=home",
    "--socket=session-bus",
    "--talk-name=org.freedesktop.systemd1"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/navetted/cargo-home",
      "RUST_BACKTRACE": "1"
    }
  },
  "modules": [
    {
      "name": "navetted",
      "buildsystem": "simple",
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ],
      "build-commands": [
        "cargo build --release --offline --frozen",
        "install -Dm755 target/release/navetted /app/bin/navetted",
        "install -Dm755 target/release/navetted-hook /app/bin/navetted-hook",
        "install -Dm644 flatpak/navetted.service /app/share/systemd/user/navetted.service",
        "install -Dm644 flatpak/io.entrevoix.navette.metainfo.xml /app/share/metainfo/io.entrevoix.navette.metainfo.xml"
      ]
    }
  ]
}
