{
  "name": "clauded-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "build:android": "eas build --platform android --profile preview",
    "ios": "expo run:ios",
    "test": "jest --forceExit"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/(?!next)|@expo-google-fonts/|react-navigation|@react-navigation/.*|expo-speech-recognition|expo-av|expo-haptics|expo-clipboard|@react-native-async-storage)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-clipboard": "~7.0.1",
    "expo-haptics": "~14.0.1",
    "expo-local-authentication": "~15.0.2",
    "expo-secure-store": "~14.0.1",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "jest": "^30.3.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.3.0"
  },
  "private": true
}
