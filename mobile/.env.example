# Android release signing — used by Gradle via gradle.properties references.
# Generate a keystore first:
#   keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore \
#     -alias navette -keyalg RSA -keysize 2048 -validity 10000
#
# Then set these before running: npm run build:release
NAVETTE_RELEASE_STORE_FILE=../release.keystore
NAVETTE_RELEASE_STORE_PASSWORD=
NAVETTE_RELEASE_KEY_ALIAS=navette
NAVETTE_RELEASE_KEY_PASSWORD=
