{
  "expo": {
    "name": "Relay",
    "slug": "relay-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Relay uses speech recognition to transcribe voice prompts.",
        "NSMicrophoneUsageDescription": "Relay uses the microphone to capture voice prompts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "io.github.bearyjd.relay",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-speech-recognition"
    ]
  }
}
